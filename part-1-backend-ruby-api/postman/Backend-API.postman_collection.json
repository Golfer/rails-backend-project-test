        },
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": {\n    \"sku_id\": \"SKU-001\",\n    \"company_id\": \"{{company_id}}\",\n    \"vendor_id\": \"{{vendor_id}}\",\n    \"name\": \"Widget X\",\n    \"lead_time_days\": 14,\n    \"days_of_stock\": 30,\n    \"forecasting_days\": 90\n  }\n}"
