{
  "info": {
    "name": "Backend API",
    "description": "Sample requests for all API v1 endpoints. Set {{baseUrl}} (e.g. http://localhost:3000) and use Auth > Login to get a token, then set {{token}} from the response or use the collection auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "company_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "vendor_id", "value": "" },
    { "key": "product_sku", "value": "" },
    { "key": "onboarding_process_id", "value": "" },
    { "key": "onboarding_step_id", "value": "" },
    { "key": "submission_id", "value": "" },
    { "key": "warehouse_id", "value": "" },
    { "key": "sales_history_id", "value": "" },
    { "key": "sync_status_id", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (new company)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"company_name\": \"Acme Corp\",\n    \"email\": \"planner@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"planner\"\n  }\n}"
            }
          }
        },
        {
          "name": "Register (existing company)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"company_id\": \"{{company_id}}\",\n    \"email\": \"planner2@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"role\": \"planner\"\n  }\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"planner@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Me (current user)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "List companies",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/companies" }
        },
        {
          "name": "Create company",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/companies",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": {\n    \"name\": \"Acme Corp\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get company",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}"
          }
        },
        {
          "name": "Update company",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": {\n    \"name\": \"Acme Corp Updated\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete company",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}"
          }
        },
        {
          "name": "Current onboarding step",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}/current_onboarding_step"
          }
        },
        {
          "name": "Sync progress",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}/sync_progress"
          }
        },
        {
          "name": "Onboarding step statuses",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/companies/{{company_id}}/onboarding_step_statuses"
          }
        }
      ]
    },
    {
      "name": "Onboarding Steps",
      "item": [
        {
          "name": "List onboarding steps",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/v1/onboarding_steps" }
        },
        {
          "name": "Create onboarding step",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_steps",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_step\": {\n    \"title\": \"Configure warehouses\",\n    \"slug\": \"warehouses\",\n    \"sort_order\": 1,\n    \"category\": \"setup\",\n    \"is_active\": true,\n    \"is_mandatory\": true\n  }\n}"
            }
          }
        },
        {
          "name": "Get onboarding step",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/onboarding_steps/{{onboarding_step_id}}"
          }
        },
        {
          "name": "Update onboarding step",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_steps/{{onboarding_step_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_step\": {\n    \"is_active\": false\n  }\n}"
            }
          }
        },
        {
          "name": "Delete onboarding step",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/onboarding_steps/{{onboarding_step_id}}"
          }
        }
      ]
    },
    {
      "name": "Onboarding Processes",
      "item": [
        {
          "name": "List onboarding processes",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/onboarding_processes?company_id={{company_id}}"
          }
        },
        {
          "name": "Create onboarding process",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_processes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_process\": {\n    \"company_id\": \"{{company_id}}\"\n  }\n}"
            }
          }
        },
        {
          "name": "Get onboarding process",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/onboarding_processes/{{onboarding_process_id}}"
          }
        },
        {
          "name": "Update onboarding process",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_processes/{{onboarding_process_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_process\": {\n    \"current_step_id\": 2\n  }\n}"
            }
          }
        },
        {
          "name": "Delete onboarding process",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/onboarding_processes/{{onboarding_process_id}}"
          }
        }
      ]
    },
    {
      "name": "Onboarding Step Submissions",
      "item": [
        {
          "name": "List submissions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/onboarding_step_submissions?company_id={{company_id}}&step_id={{onboarding_step_id}}"
          }
        },
        {
          "name": "Create submission",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_step_submissions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_step_submission\": {\n    \"company_id\": \"{{company_id}}\",\n    \"step_id\": 1,\n    \"status\": \"completed\",\n    \"values\": { \"days\": 63 },\n    \"completed_at\": null\n  }\n}"
            }
          }
        },
        {
          "name": "Get submission",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/onboarding_step_submissions/{{submission_id}}"
          }
        },
        {
          "name": "Update submission",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/onboarding_step_submissions/{{submission_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"onboarding_step_submission\": {\n    \"status\": \"skipped\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete submission",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/v1/onboarding_step_submissions/{{submission_id}}"
          }
        }
      ]
    },
