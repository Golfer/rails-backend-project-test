              "raw": "{\n  \"vendor\": {\n    \"company_id\": \"{{company_id}}\",\n    \"name\": \"Supplier A\",\n    \"contact_info\": { \"phone\": \"+123\", \"email\": \"supplier@a.com\" }\n  }\n}"
